# server config
PORT=5000

# mongodb connection string (use MongoDB Atlas or a local instance)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/handscript-ai

# any random secret string for signing JWT tokens
JWT_SECRET=change-this-to-something-random

# google oauth (get these from console.cloud.google.com)
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# frontend url
CLIENT_URL=http://localhost:5173
